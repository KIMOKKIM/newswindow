PORT=3001
JWT_SECRET=your-secret-change-in-production
CORS_ORIGIN=http://127.0.0.1:8080

# ━━━ Supabase (권장: 영구 저장) ━━━
# Vercel/Render 변수 이름은 반드시 아래와 동일하게 (SUPABASE_ 접두사):
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # 서버 전용, anon 키가 아님
# SUPABASE_BANNERS_BUCKET=banners
#
# After creating view public.articles_list_slim (see scripts/supabase-home-perf.sql), list APIs use it by default.
# Fallback if view missing: NW_ARTICLES_TABLE_LIST=articles
#
# 로컬 개발 전용: 기사·사용자를 JSON 파일로만 쓸 때 (운영 NODE_ENV=production·RENDER 에서는 무시됨):
# NW_DEV_LEGACY_FILE_DB=1

# ━━━ 재배포 후에도 기사·광고·업로드이미지·사용자를 유지하려면 (Render Persistent Disk 등) ━━━
# 디스크를 예: /data 에 마운트한 뒤 아래를 모두 설정하는 것을 권장합니다.
# 미설정 시 backend/data · backend/uploads 에 저장되며, 컨테이너 재시작·재배포마다 초기화됩니다.
#
# NW_ARTICLES_JSON_PATH=/data/articles.json
# NW_ADS_JSON_PATH=/data/ads.json
# NW_USERS_JSON_PATH=/data/users.json
# NW_UPLOADS_ROOT=/data/uploads
#
# 운영에서 기본 경로 사용 시 콘솔 경고를 강제하려면:
# NW_PERSISTENCE_WARN=1
